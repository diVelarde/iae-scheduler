generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Schedule {
  schedule_id Int      @id @default(autoincrement())
  course_code String
  section     String
  room_id     String
  day         String
  start_time  DateTime
  end_time    DateTime

  created_at  DateTime @default(now())
}
